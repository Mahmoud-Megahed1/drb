# Protect JSON data files from direct access
<FilesMatch "\.(json|log|txt)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# Deny all access to this directory
Options -Indexes
